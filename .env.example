# Contact form delivery (Resend)
RESEND_API_KEY=

# Where contact form submissions land. Defaults to site.email if unset.
CONTACT_TO_EMAIL=

# From address. Must be a domain verified in Resend, or use onboarding@resend.dev in dev.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# OpenAI key for `npm run generate:art` (gpt-image-1). Build-time only — never read at runtime.
OPENAI_API_KEY=
